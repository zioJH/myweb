        <script>
            let currentBeer = 0;
            const beerSlides = document.querySelectorAll('.beer-slide');
            const bgColors = ['#9B1C31', '#D4AF37', '#1A2A40', '#3A7D44'];

            <!-- 맥주 슬라이드 이동 함수 -->
            function moveBeerSlide(dir) {
                const current = beerSlides[currentBeer];
                current.style.opacity = '0';
                current.style.transform = 'translateX(' + (dir > 0 ? '-60px' : '60px') + ')';

                setTimeout(() => {
                    current.style.display = 'none';
                    current.style.transform = 'translateX(0)';
                    currentBeer = (currentBeer + dir + beerSlides.length) % beerSlides.length;
                    const next = beerSlides[currentBeer];
                    next.style.display = 'flex';
                    next.style.opacity = '0';
                    next.style.transform = 'translateX(' + (dir > 0 ? '60px' : '-60px') + ')';
                    setTimeout(() => {
                        next.style.opacity = '1';
                        next.style.transform = 'translateX(0)';
                        document.getElementById('beerSlider').style.background = bgColors[currentBeer];
                        document.getElementById('beerHeader').style.background = bgColors[currentBeer];
                    }, 30);
                }, 300);
            }
        </script>

        <!-- 헤더 이미지 슬라이드 -->
        <script>
            const headerImages = [
                'assets/img/header.jpg',
                'assets/img/header2.jpg',
                'assets/img/header3.jpg'
            ];
            let currentHeader = 0;
            const header = document.getElementById('mastheadHeader');

            setInterval(() => {
                currentHeader = (currentHeader + 1) % headerImages.length;
                header.style.transition = 'opacity 0.8s ease';
                header.style.opacity = '0';
                setTimeout(() => {
                    header.style.backgroundImage =
                        'linear-gradient(to bottom, rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url("' + headerImages[currentHeader] + '")';
                    header.style.opacity = '1';
                }, 800);
            }, 4000); 
