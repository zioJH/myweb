<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>BEER NAME 01 – Art Monster</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.5.0/font/bootstrap-icons.css" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css?family=Merriweather+Sans:400,700" rel="stylesheet"/>
    <link href="css/styles.css" rel="stylesheet"/>
    <style>
        * { box-sizing: border-box; }
        body { background:#0d0d0d; color:#fff; margin:0; font-family:'Merriweather Sans', sans-serif; }
        a { text-decoration:none; }

        /* 히어로 */
        .hero {
            min-height:100vh; display:flex; align-items:center;
            background: linear-gradient(135deg, #9B1C31 0%, #373636 100%);
            padding: 6rem 0 3rem;
            position:relative; overflow:hidden;
        }
        .hero::before {
            content:'01';
            position:absolute; right:4rem; bottom:-2rem;
            font-size:20rem; font-weight:900;
            color:rgba(255,255,255,0.04); line-height:1;
            pointer-events:none;
        }
        .hero-inner {
            max-width:1200px; margin:0 auto; padding:0 4rem;
            display:flex; align-items:center; gap:6rem; width:100%;
        }
        .hero-text { flex:1; }
        .hero-text .label {
            font-size:0.7rem; letter-spacing:4px; text-transform:uppercase;
            color:rgba(255,255,255,0.5); margin-bottom:1rem;
        }
        .hero-text h1 {
            font-size:5rem; font-weight:900; line-height:1; margin:0 0 1.5rem;
        }
        .hero-text .style-tag {
            display:inline-block; border:1px solid rgba(255,255,255,0.3);
            padding:0.4rem 1.2rem; font-size:0.8rem; letter-spacing:2px;
            text-transform:uppercase; color:rgba(255,255,255,0.7); margin-bottom:2rem;
        }
        .hero-text .tagline {
            font-size:1.1rem; color:rgba(255,255,255,0.65); line-height:1.8; max-width:420px;
        }
        .hero-img { flex:1; text-align:center; }
        .hero-img img {
            max-height:520px; max-width:100%;
            filter:drop-shadow(0 20px 60px rgba(0,0,0,0.6));
            transition:transform 0.4s;
        }
        .hero-img img:hover { transform:scale(1.04) translateY(-8px); }

        /* 스탯 바 */
        .stats-bar {
            background:#161616; border-top:1px solid #222; border-bottom:1px solid #222;
        }
        .stats-bar .inner {
            max-width:1200px; margin:0 auto; padding:2.5rem 4rem;
            display:flex; gap:0;
        }
        .stat-item {
            flex:1; text-align:center; padding:1rem;
            border-right:1px solid #2a2a2a;
        }
        .stat-item:last-child { border-right:none; }
        .stat-item .num {
            font-size:2.8rem; font-weight:900; color:#fff; line-height:1;
        }
        .stat-item .text {
            font-size:2rem; font-weight:900; color:#fff; line-height:1;
        }
        .stat-item .unit {
            font-size:1rem; color:rgba(255,255,255,0.4); margin-left:2px;
        }
        .stat-item .desc {
            font-size:0.7rem; letter-spacing:3px; text-transform:uppercase;
            color:rgba(255,255,255,0.35); margin-top:0.5rem;
        }

        .detail-section {
            max-width:1200px; margin:0 auto; padding:6rem 4rem;
        }
        .section-label {
            font-size:0.7rem; letter-spacing:4px; text-transform:uppercase;
            color:#8B1A1A; margin-bottom:1rem;
        }
        .section-title {
            font-size:2.2rem; font-weight:900; margin:0 0 3rem;
        }

        /* 맛 노트 */
        .flavor-grid {
            display:grid; grid-template-columns:repeat(3,1fr); gap:2rem;
        }
        .flavor-card {
            background:#161616; border:1px solid #222; padding:2rem;
            border-radius:4px; transition:border-color 0.2s;
        }
        .flavor-card:hover { border-color:#8B1A1A; }
        .flavor-card .icon { font-size:2rem; margin-bottom:1rem; }
        .flavor-card h4 { font-size:0.8rem; letter-spacing:3px; text-transform:uppercase; color:rgba(255,255,255,0.4); margin-bottom:0.8rem; }
        .flavor-card p { color:rgba(255,255,255,0.75); line-height:1.8; font-size:0.95rem; }

        @media(max-width:768px){
            .hero-inner { flex-direction:column; padding:0 2rem; gap:3rem; }
            .hero-text h1 { font-size:3rem; }
            .hero::before { font-size:10rem; }
            .flavor-grid, .pairing-grid { grid-template-columns:1fr; }
            .stats-bar .inner { flex-wrap:wrap; }
            .stat-item { flex:0 0 50%; border-right:none; border-bottom:1px solid #2a2a2a; }
            .detail-section { padding:4rem 2rem; }
            .hero-arrow { width:40px; height:40px; font-size:1rem; }
            .hero-arrow-prev { left:1rem; }
            .hero-arrow-next { right:1rem; }
        }

        /* Footer */
        .st-footer {
            padding: 3rem 8vw;
            background: #000;
            border-top: 1px solid rgba(255,255,255,0.06);
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 1rem;
        }
        .st-footer-brand {
            font-weight: 700;
            letter-spacing: 2px;
            font-size: 0.9rem;
        }
        .st-footer small {
            color: rgba(255,255,255,0.3);
            font-size: 0.75rem;
        }
        .st-footer-back {
            font-size: 0.75rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: rgba(255,255,255,0.4);
            text-decoration: none;
            transition: color 0.2s;
        }
        .st-footer-back:hover { color: #fff; }

        @media (max-width: 768px) {
            .how-inner { flex-direction: column; }
            .how-left, .how-right { padding: 4rem 6vw; }
            .features-grid { grid-template-columns: 1fr; }
            .features-inner { padding: 5rem 6vw; }
        }

        /* SNS */
        .bottom-bar {
            border-top: 1px solid #1a1a1a;
            padding: 3rem;
            display: flex; align-items: center; justify-content: space-between;
            flex-wrap: wrap; gap: 2rem;
        }
        .sns-row { display: flex; gap: 1.5rem; align-items: center; }
        .sns-link {
            color: rgba(255,255,255,0.35); font-size: 1.3rem;
            transition: color .2s;
        }
    </style>
</head>
