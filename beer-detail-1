        <style>
            body { background-color: #000 !important; color: #fff; }
            .btn-primary { background-color: #8B1A1A !important; border-color: #8B1A1A !important; }
            .btn-primary:hover { background-color: #6e1414 !important; }
            #mainNav.navbar-shrink { background-color: #0000006a !important; }

            /* 히어로 */
            .st-hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
            background: #0a0a0a;
            }
            .st-hero-bg {
                position: absolute; inset: 0;
                background:
                    radial-gradient(ellipse 60% 50% at 70% 50%, rgba(139,26,26,0.18) 0%, transparent 70%),
                    radial-gradient(ellipse 40% 60% at 20% 80%, rgba(139,26,26,0.08) 0%, transparent 60%);
            }
            .st-hero-grid {
                position: absolute; inset: 0;
                background-image:
                    linear-gradient(rgba(139,26,26,0.07) 1px, transparent 1px),
                    linear-gradient(90deg, rgba(139,26,26,0.07) 1px, transparent 1px);
                background-size: 80px 80px;
                animation: gridMove 20s linear infinite;
            }
            @keyframes gridMove {
                0%   { transform: translateY(0); }
                100% { transform: translateY(80px); }
            }
            .st-hero-content {
                position: relative; z-index: 2;
                text-align: center;
                padding: 2rem;
            }
            .st-eyebrow {
                font-size: 0.7rem;
                letter-spacing: 5px;
                text-transform: uppercase;
                color: #8B1A1A;
                margin-bottom: 2rem;
            }
            .st-hero-title {
                font-family: 'Merriweather', serif;
                font-size: clamp(2.8rem, 7vw, 6rem);
                font-weight: 900;
                line-height: 1.05;
                margin: 0 0 1.5rem;
                letter-spacing: -1px;
            }
            .st-hero-title span { color: #8B1A1A; }
            .st-hero-sub {
                color: rgba(255,255,255,0.55);
                font-size: 1rem;
                max-width: 460px;
                margin: 0 auto 3rem;
                line-height: 1.8;
            }
            .tap-device {
                width: 120px;
                height: 120px;
                margin: 0 auto 2.5rem;
                position: relative;
            }
            
            /* 지도 */
            .map-section {
                display: flex; min-height: 520px;
                border-top: 1px solid #1a1a1a;
                border-bottom: 1px solid #1a1a1a;
            }
            .map-panel {
                flex: 1.3; position: relative; overflow: hidden;
            }
            .map-panel iframe {
                width: 100%; height: 100%; border: 0; display: block; min-height: 420px;
                filter: grayscale(30%) contrast(1.05);
            }

            .map-panel::before {
                content: '';
                position: absolute; top: 0; right: 0; bottom: 0;
                width: 3px; background: #8B1A1A; z-index: 1;
            }
            .info-panel {
                flex: 1; background: #111;
                display: flex; flex-direction: column; justify-content: center;
                padding: 4rem 4.5rem;
                gap: 0;
            }

            /* info 소개 */
            .info-block { margin-bottom: 2.5rem; }
            .info-block:last-child { margin-bottom: 0; }
            .info-label {
                font-size: 0.6rem; letter-spacing: 4px; text-transform: uppercase;
                color: #8B1A1A; margin-bottom: 0.7rem; font-weight: 700;
                display: flex; align-items: center; gap: 0.5rem;
            }
            .info-label::after {
                content: ''; flex: 1; height: 1px; background: rgba(139,26,26,0.25);
            }
            .info-value {
                font-size: 1.15rem; font-weight: 700; color: #fff;
                line-height: 1.5; margin-bottom: 0.3rem;
            }
            .info-note { font-size: 0.82rem; color: rgba(255,255,255,0.38); }

            .hours-row {
                display: flex; justify-content: space-between;
                align-items: baseline; padding: 0.55rem 0;
                border-bottom: 1px solid rgba(255,255,255,0.05);
            }
            .hours-row:last-child { border-bottom: none; }
            .hours-day { font-size: 0.78rem; color: rgba(255,255,255,0.45); letter-spacing: 1px; }
            .hours-time { font-size: 0.9rem; color: #fff; font-weight: 700; letter-spacing: 1px; }
            .hours-closed { color: rgba(255,255,255,0.25); font-style: italic; }

            /* SNS */
            .bottom-bar {
                border-top: 1px solid #1a1a1a;
                padding: 3rem;
                display: flex; align-items: center; justify-content: space-between;
                flex-wrap: wrap; gap: 2rem;
            }
            .sns-row { display: flex; gap: 1.5rem; align-items: center; }
            .sns-link {
                color: rgba(255,255,255,0.35); font-size: 1.3rem;
                transition: color .2s;
            }

            /* Event */
            .eyebrow {
                font-size: 0.7rem;
                letter-spacing: 5px;
                text-transform: uppercase;
                color: #8B1A1A;
                margin-bottom: 1.2rem;
                display: block;
            }
            .ev-featured {
                min-height: 100vh;
                display: flex;
                background: #0d0d0d;
            }
            .ev-featured-left {
                flex: 1.1;
                position: relative;
                overflow: hidden;
                background: #111;
                display: flex;
                align-items: center;
                justify-content: center;
                min-height: 50vh;
            }
            /* 포스터 */
            .ev-poster-mock {
                width: 280px;
                aspect-ratio: 2/3;
                background: linear-gradient(145deg, #1a0505 0%, #2d0808 50%, #8B1A1A 100%);
                border: 1px solid rgba(139,26,26,0.3);
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                position: relative;
                overflow: hidden;
            }
            .ev-poster-mock::before {
                content: '';
                position: absolute;
                top: -30%; left: -30%;
                width: 160%; height: 160%;
                background: radial-gradient(circle at 60% 40%, rgba(255,255,255,0.05) 0%, transparent 60%);
            }
            .ev-poster-label {
                font-size: 0.6rem;
                letter-spacing: 4px;
                color: rgba(255,255,255,0.4);
                text-transform: uppercase;
                margin-bottom: 1.5rem;
            }
            .ev-poster-title {
                font-family: 'Merriweather', serif;
                font-size: 2rem;
                font-weight: 900;
                text-align: center;
                line-height: 1.1;
            }
            .ev-poster-date-tag {
                position: absolute;
                bottom: 1.5rem;
                left: 50%; transform: translateX(-50%);
                font-size: 0.65rem;
                letter-spacing: 2px;
                color: rgba(255,255,255,0.5);
                white-space: nowrap;
            }

            .ev-featured-right {
                flex: 1;
                display: flex;
                flex-direction: column;
                justify-content: center;
                padding: 6rem 8vw 6rem 5rem;
            }
            .ev-featured-right h2 {
                font-family: 'Merriweather', serif;
                font-size: clamp(2rem, 3.5vw, 3rem);
                font-weight: 900;
                line-height: 1.1;
                margin: 0 0 1rem;
            }
            .ev-featured-right p {
                color: rgba(255,255,255,0.5);
                font-size: 0.9rem;
                line-height: 1.9;
                margin-bottom: 2.5rem;
                max-width: 400px;
            }
            .ev-detail-list {
                list-style: none;
                padding: 0; margin: 0 0 2.5rem;
                display: flex;
                flex-direction: column;
                gap: 1rem;
            }
            .ev-detail-list li {
                display: flex;
                align-items: center;
                gap: 1rem;
                font-size: 0.85rem;
                color: rgba(255,255,255,0.6);
            }
            .ev-detail-list li i {
                color: #8B1A1A;
                font-size: 1rem;
                width: 1.2rem;
                flex-shrink: 0;
            }

            /* Tasting Class */
            :root {
                --red:    #8B1A1A;
                --red-dk: #6e1414;
                --gold:   #C9A84C;
                --bg:     #060606;
                --bg2:    #0e0e0e;
                --line:   rgba(255,255,255,0.07);
                --muted:  rgba(255,255,255,0.38);
            }
            .tc-classes {
                max-width: 1200px; margin: 0 auto;
                padding: 7rem 4rem;
            }
            .tc-classes-header {
                display: flex; align-items: flex-end; justify-content: space-between;
                margin-bottom: 4rem; flex-wrap: wrap; gap: 1rem;
            }
            .tc-classes-header h2 {
                font-family: 'Merriweather', serif;
                font-size: clamp(1.6rem, 3vw, 2.4rem);
                font-weight: 900; line-height: 1.1;
            }
            .tc-class-grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 1.5rem;
            }
            .tc-class-card {
                border: 3px solid var(--line);
                padding: 2.5rem 2rem;
                position: relative; overflow: hidden;
                transition: border-color 0.25s;
                cursor: pointer;
            }
            .tc-class-card:hover { border-color: var(--red); }
            .tc-class-card:hover::before { transform: scaleX(1); }

            .tc-class-card .card-num {
                font-size: 3.5rem; font-weight: 900; line-height: 1;
                color: rgba(201,168,76,0.12); margin-bottom: 1.5rem;
            }
            .tc-class-card .card-level {
                font-size: 0.6rem; letter-spacing: 4px; text-transform: uppercase;
                color: var(--red); margin-bottom: 0.8rem;
            }
            .tc-class-card h3 {
                font-size: 1.15rem; font-weight: 700; margin-bottom: 1rem;
            }
            .tc-class-card p {
                color: var(--muted); font-size: 0.88rem; line-height: 1.9;
                margin-bottom: 1.8rem;
            }
            .tc-class-meta {
                display: flex; flex-direction: column; gap: 0.5rem;
                padding-top: 1.5rem;
                border-top: 1px solid var(--line);
            }
            .tc-class-meta .meta-row {
                display: flex; align-items: center; gap: 0.6rem;
                font-size: 0.75rem; color: rgba(255,255,255,0.5);
            }
            .eyebrow {
                font-size: 0.65rem; letter-spacing: 5px; text-transform: uppercase;
                color: #8B1A1A; display: block; margin-bottom: 1.5rem;
            }
        </style>
